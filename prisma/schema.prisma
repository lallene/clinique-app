generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
  // L'URL est gérée dans prisma.config.ts en Prisma 7
}

model Utilisateur {
  idUser        Int              @id @default(autoincrement()) @map("id_user")
  login         String           @unique
  motDePasse    String           @map("mot_de_passe")
  nom           String?
  prenom        String?
  role          String           // administrateur, medecin, infirmier, caisse, direction
  actif         Boolean          @default(true)

  consultations      Consultation[]
  factures           Facture[]
  logs               LogAudit[]
  hospitalisations   Hospitalisation[] @relation("MedecinHospitalisation")
  rendezvous         RendezVous[]      @relation("MedecinRendezVous")

  @@map("utilisateur")
}

model CompagnieAssurance {
  idCompagnie    Int         @id @default(autoincrement()) @map("id_compagnie")
  nomCompagnie   String      @unique @map("nom_compagnie") // ex: ASCOMA, MUGEF-CI, NSIA
  assurances     Assurance[]

  @@map("compagnie_assurance")
}

model Assurance {
  idAssurance    Int                @id @default(autoincrement()) @map("id_assurance")
  compagnieId    Int                @map("compagnie_id")
  compagnie      CompagnieAssurance @relation(fields: [compagnieId], references: [idCompagnie])
  
  nomGarant      String             @map("nom_garant") // ex: CONCENTRIX, PORTEO, TOTAL
  contact        String?
  convention     String?   
  
  patients       Patient[]
  factures       Facture[]

  @@map("assurance")
}

model Patient {
  id_patient       Int              @id @default(autoincrement()) @map("id_patient")
  codePatient     String?           @unique @map("code_patient")
  nom             String
  prenoms         String?          
  sexe            String?          
  dateNaissance   DateTime?        @map("date_naissance")
  age             Int?             
  telephone       String?          
  quartier        String?          
  personneContact String?          @map("personne_contact")
  numeroDossier   String?          @unique @map("numero_dossier")

  // Volet Assurance
  isAssure        Boolean          @default(false) @map("is_assure")
  tauxCouverture  Float?           @default(0) @map("taux_couverture")
  matriculeAssure String?          @map("matricule_assure")
  
  assuranceId     Int?             @map("assurance_id")
  assurance       Assurance?       @relation(fields: [assuranceId], references: [idAssurance])

  consultations    Consultation[]
  hospitalisations Hospitalisation[]
  factures         Facture[]
  examens          Examen[]
  rendezvous       RendezVous[]
  mouvementsPharmacie MvtPharmacie[]

  @@map("patient")
}

model Consultation {
  idConsultation Int       @id @default(autoincrement()) @map("id_consultation")
  dateConsultation DateTime @default(now()) @map("date_consultation")
  motif           String?
  antecedents     String?
  constantes      String?
  diagnostic      String?
  prescription    String?
  compteRendu     String?  @map("compte_rendu")
  
  patientId       Int      @map("patient_id")
  patient         Patient  @relation(fields: [patientId], references: [id_patient])
  
  medecinId       Int?     @map("medecin_id")
  medecin         Utilisateur? @relation(fields: [medecinId], references: [idUser])
  
  serviceId       Int?     @map("service_id")
  service         Service?     @relation(fields: [serviceId], references: [idService])

  examens Examen[] @relation("ConsultationExamens")

  @@map("consultation")
}

model Service {
  idService   Int      @id @default(autoincrement()) @map("id_service")
  nomService  String   @map("nom_service")
  typeService String?  @map("type_service")
  consultations Consultation[]
  rendezvous  RendezVous[]

  @@map("service")
}

model Hospitalisation {
  idHospit         Int       @id @default(autoincrement()) @map("id_hospit")
  patientId        Int       @map("patient_id")
  patient          Patient   @relation(fields: [patientId], references: [id_patient])
  dateEntree       DateTime  @default(now()) @map("date_entree")
  dateSortie       DateTime? @map("date_sortie")
  diagnosticEntree String?   @map("diagnostic_entree")
  medecinResponsable Int?    @map("medecin_responsable")
  medecin          Utilisateur? @relation("MedecinHospitalisation", fields: [medecinResponsable], references: [idUser])
  chambre          String?
  lit              String?
  statut           String?   @default("en_cours")
  mouvementsPharmacie MvtPharmacie[]

  @@map("hospitalisation")
}

model Examen {
  idExamen        Int       @id @default(autoincrement()) @map("id_examen")
  patientId       Int       @map("patient_id")
  patient         Patient   @relation(fields: [patientId], references: [id_patient])
  consultationId  Int?      @map("consultation_id")
  consultation    Consultation? @relation("ConsultationExamens", fields: [consultationId], references: [idConsultation])
  typeExamen      String    @map("type_examen")
  resultat        String?
  statut          String?   @default("demande")
  dateDemande     DateTime  @default(now()) @map("date_demande")
  dateRealisation DateTime? @map("date_realisation")
  dateValidation  DateTime? @map("date_validation")

  @@map("examen")
}

model Facture {
  idFacture        Int       @id @default(autoincrement()) @map("id_facture")
  numeroFacture    String    @unique @map("numero_facture")
  dateFacture      DateTime  @default(now()) @map("date_facture")
  montantTotal     Float     @map("montant_total")
  montantPatient   Float?    @map("montant_patient")
  montantAssurance Float?    @map("montant_assurance")
  statut           String?   @default("brouillon")
  
  patientId        Int       @map("patient_id")
  patient          Patient   @relation(fields: [patientId], references: [id_patient])
  
  assuranceId      Int?      @map("assurance_id")
  assurance        Assurance? @relation(fields: [assuranceId], references: [idAssurance])
  
  creePar          Int?      @map("cree_par")
  utilisateur      Utilisateur? @relation(fields: [creePar], references: [idUser])
  paiements        Paiement[]

  @@map("facture")
}

model Paiement {
  idPaiement    Int      @id @default(autoincrement()) @map("id_paiement")
  datePaiement  DateTime @default(now()) @map("date_paiement")
  montant       Float
  modePaiement  String?  @map("mode_paiement")
  factureId     Int      @map("facture_id")
  facture       Facture  @relation(fields: [factureId], references: [idFacture])

  @@map("paiement")
}

model ProduitPharmacie {
  idProduit     Int     @id @default(autoincrement()) @map("id_produit")
  codeProduit   String? @unique @map("code_produit")
  nomProduit    String  @map("nom_produit")
  forme         String?
  prixAchat     Float   @map("prix_achat")
  prixVente     Float   @map("prix_vente")
  quantiteStock Int     @default(0) @map("quantite_stock")
  mvtPharmacie  MvtPharmacie[]

  @@map("produit_pharmacie")
}

model MvtPharmacie {
  idMvt      Int        @id @default(autoincrement()) @map("id_mvt")
  produitId  Int        @map("produit_id")
  produit    ProduitPharmacie @relation(fields: [produitId], references: [idProduit])
  patientId  Int?       @map("patient_id")
  patient    Patient?   @relation(fields: [patientId], references: [id_patient])
  hospitId   Int?       @map("hospit_id")
  hospitalisation Hospitalisation? @relation(fields: [hospitId], references: [idHospit])
  typeMvt    String     @map("type_mvt") // ENTREE, SORTIE
  qte        Float
  dateMvt    DateTime  @default(now()) @map("date_mvt")

  @@map("mouvement_pharmacie")
}

model RendezVous {
  idRdv      Int       @id @default(autoincrement()) @map("id_rdv")
  patientId  Int       @map("patient_id")
  patient    Patient   @relation(fields: [patientId], references: [id_patient])
  medecinId  Int?      @map("medecin_id")
  medecin    Utilisateur? @relation("MedecinRendezVous", fields: [medecinId], references: [idUser])
  serviceId  Int?      @map("service_id")
  service    Service?  @relation(fields: [serviceId], references: [idService])
  dateRdv    DateTime  @map("date_rdv")
  statut     String?   @default("planifie")

  @@map("rendez_vous")
}

model LogAudit {
  idLog         Int      @id @default(autoincrement()) @map("id_log")
  dateAction    DateTime @default(now()) @map("date_action")
  utilisateurId Int?     @map("utilisateur_id")
  utilisateur   Utilisateur? @relation(fields: [utilisateurId], references: [idUser])
  tableImpactee String   @map("table_impactee")
  typeAction    String   @map("type_action")
  details       String?

  @@map("log_audit")
}

// Modèles pour NextAuth (Optionnels si tu utilises Utilisateur pour tout)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  image         String?
  role          String    @default("USER")
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}